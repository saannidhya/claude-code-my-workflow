# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
# .vscode/settings.json ships in the template (carries shipped Claude Code permission-mode
# recommendations — see TROUBLESHOOTING.md "Permissions / bypass / statusline" for the typo
# fix forkers need). Other .vscode/ content is developer-machine-specific.
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
.quarto/

# quality_reports/ — per-project session logs, plans, specs, merges.
# The directory structure ships in the template (via .gitkeep), but the
# content is PROJECT-INTERNAL and shouldn't be inherited by forks.
quality_reports/plans/*
quality_reports/specs/*
quality_reports/session_logs/*
quality_reports/merges/*
quality_reports/decisions/*
quality_reports/checkpoints/*
quality_reports/preregistrations/*
!quality_reports/plans/.gitkeep
!quality_reports/specs/.gitkeep
!quality_reports/session_logs/.gitkeep
!quality_reports/merges/.gitkeep
!quality_reports/decisions/.gitkeep
!quality_reports/checkpoints/.gitkeep
!quality_reports/preregistrations/.gitkeep

# R analysis outputs (generated artifacts; keep scripts, ignore outputs)
scripts/R/_outputs/

# ignore data folder 
data/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds

# ==============================================================================
# CoreLogic Research project additions (2026-05-18)
# ==============================================================================

# Data working store — data/ is gitignored above; these are explicit per-subdirectory
# .gitkeep allowances so the directory structure ships in fresh clones.
!data/.gitkeep
!data/README.md
!data/corelogic_extracts/.gitkeep
!data/corelogic_baseline/.gitkeep
!data/corelogic_baseline/PROVENANCE.md
!data/external/.gitkeep
!data/derived/.gitkeep

# Per-project intermediate outputs (gitignored; .gitkeep ships)
projects/*/scripts/R/_outputs/
projects/*/scripts/python/_outputs/
projects/*/scripts/julia/_outputs/
!projects/*/scripts/R/_outputs/.gitkeep
!projects/*/scripts/python/_outputs/.gitkeep
!projects/*/scripts/julia/_outputs/.gitkeep

# Per-project LaTeX build artifacts
projects/*/manuscript/*.aux
projects/*/manuscript/*.bbl
projects/*/manuscript/*.blg
projects/*/manuscript/*.log
projects/*/manuscript/*.out
projects/*/manuscript/*.toc
projects/*/manuscript/*.fls
projects/*/manuscript/*.fdb_latexmk
projects/*/manuscript/*.synctex.gz
projects/*/slides/*.aux
projects/*/slides/*.log
projects/*/slides/*.nav
projects/*/slides/*.out
projects/*/slides/*.snm
projects/*/slides/*.toc
projects/*/slides/*.vrb

# Parquet/Arrow files anywhere (always gitignored — too big, regenerable)
*.parquet
*.arrow
*.feather

# R environment management
renv/library/
renv/local/
renv/staging/
renv/python/
renv/sandbox/
!renv/activate.R
!renv/settings.json

# Python environment management
.venv/
.uv/
__pycache__/
*.egg-info/

# Julia depot (local install caches)
.julia/
